# Auth
SECRET_KEY="your_secret_key_here"
ALGORITHM="HS256"
TOKEN_EXP_SECONDS=86400

# Bucket / S3
BUCKET_HOST="https://your-bucket-url.com/"
URL_EXPIRATION=3600
AWS_ACCESS_KEY_ID="your_access_key"
AWS_SECRET_ACCESS_KEY="your_secret_key"
BUCKET_NAME="musique"
AWS_ENDPOINT_URL="https://your-endpoint.com"

# Database Configuration
# DATABASE_TYPE can be 'sqlite' or 'postgres'
DATABASE_TYPE=postgres
PGHOST=db
PGPORT=5432
PGDATABASE=musique
PGUSER=postgres
PGPASSWORD=postgres

# Discogs API
DISCOGS_TOKEN="your_discogs_token"
DISCOGS_USER_AGENT="YourApp/1.0"
